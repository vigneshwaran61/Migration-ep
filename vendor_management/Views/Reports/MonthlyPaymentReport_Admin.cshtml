@model SYS_VENDOR_MGMT.Models.MonthlyPaymentReportViewModel
@{
    ViewData["Title"] = "Monthly Payment Report";
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <span id="lblErrormsg" style="color:red; font-family:Verdana; font-size:10pt;">@Model.ErrorMessage</span>
}
@if (TempData["ErrorMsg"] is string errMsg && !string.IsNullOrEmpty(errMsg))
{
    <span id="lblErrormsgTemp" style="color:red; font-family:Verdana; font-size:10pt;">@errMsg</span>
}

<!-- ═══ SEARCH PANEL ════════════════════════════════════════════════════════ -->
<div class="Panel" style="padding:10px; border:1px solid #ccc; margin-bottom:10px;">
    <fieldset><legend>Search</legend>
    <table cellpadding="1" cellspacing="0" border="0" class="Text" style="padding-left:2px; padding-top:20px;" width="800px">
        <tr>
            <td width="100px" class="lbl1">Month</td>
            <td width="2px" align="center" class="lbl1">:</td>
            <td width="250px">
                <select id="ddlMonth" name="SelectedMonth" class="DDL" onchange="onMonthChange(this)">
                    @foreach (var item in Model.Months)
                    {
                        <option value="@item.Value"
                                @(item.Value == Model.Search.SelectedMonth ? "selected" : "")>
                            @item.Text
                        </option>
                    }
                </select>
            </td>
            <td></td>
        </tr>
        <tr id="trRate" style="display:@(string.IsNullOrEmpty(Model.Search.SelectedMonth) ? "none" : "")">
            <td width="100px" class="lbl1">Vendor</td>
            <td width="2px" align="center" class="lbl1">:</td>
            <td width="250px">
                <select id="ddlVendor" name="SelectedVendorCode" class="DDL" onchange="onVendorChange(this)">
                    <option value=""> -Select- </option>
                </select>
            </td>
            <td></td>
        </tr>
        <tr id="trSearch" style="display:@(string.IsNullOrEmpty(Model.Search.SelectedPOValue) ? "none" : "")">
            <td width="100px" class="lbl1">PO Number</td>
            <td width="2px" align="center" class="lbl1">:</td>
            <td>
                <select id="ddlPONo" name="SelectedPOValue" class="DDL">
                    <option value=""> -Select- </option>
                </select>
            </td>
            <td>
                <!-- Search -->
                <form id="frmSearch" method="post" asp-action="Search">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SelectedMonth"      id="hSelectedMonth"  value="@Model.Search.SelectedMonth" />
                    <input type="hidden" name="SelectedVendorCode" id="hVendorCode"      value="@Model.Search.SelectedVendorCode" />
                    <input type="hidden" name="SelectedVendorText" id="hVendorText"      value="@Model.Search.SelectedVendorText" />
                    <input type="hidden" name="SelectedPOValue"    id="hPOValue"         value="@Model.Search.SelectedPOValue" />
                    <input type="hidden" name="SelectedPOText"     id="hPOText"          value="@Model.Search.SelectedPOText" />
                    <button type="submit" class="button" onclick="syncHiddens()">Search</button>
                </form>
            </td>
        </tr>
    </table>
    </fieldset>
</div>

<!-- ═══ DETAILS PANEL ═══════════════════════════════════════════════════════ -->
@if (Model.ShowDetails)
{
    <div class="Panel" style="padding:10px; border:1px solid #ccc; margin-bottom:10px;">
    <fieldset><legend>Monthly Payment Report</legend>
    <div id="divPDF">
        <table cellpadding="1" cellspacing="0" border="0" class="Text" style="padding-left:10px; padding-top:20px;">
            <tr>
                <td align="center" colspan="2">
                    <span id="lblHeader" class="lbl1" style="font-weight:bold; text-decoration:underline;">@Model.Header</span>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <table>
                        <tr>
                            <td class="lbl1">PO number</td><td>:</td>
                            <td><span id="lblPONo" class="lbl1">@Model.Details.PONumber</span></td>
                            <td>&nbsp;</td>
                            <td class="lbl1">Rate Revision</td><td>:</td>
                            <td><span id="lblRateRev" class="lbl1">@Model.Details.RateSequence</span></td>
                        </tr>
                        <tr>
                            <td class="lbl1">PO Effect From</td><td>:</td>
                            <td><span id="lblPoEffectFrom" class="lbl1">@Model.Details.POEffectFrom</span></td>
                            <td>&nbsp;</td>
                            <td class="lbl1">PO Effect To</td><td>:</td>
                            <td><span id="lblPOEffectTo" class="lbl1">@Model.Details.POEffectTo</span></td>
                        </tr>
                        <tr>
                            <td class="lbl1">Vendor Code</td><td>:</td>
                            <td><span id="lblVendorCode" class="lbl1">@Model.Details.VendorCode</span></td>
                            <td>&nbsp;</td>
                            <td class="lbl1">Vendor Name</td><td>:</td>
                            <td><span id="lblVendorName" class="lbl1">@Model.Details.VendorName</span></td>
                        </tr>
                        <tr>
                            <td class="lbl1">Total No. Of Units</td><td>:</td>
                            <td><span id="lblResCount" class="lbl1">@Model.Details.NoOfUnits</span></td>
                            <td>&nbsp;</td>
                            <td class="lbl1">Total Month Days</td><td>:</td>
                            <td><span id="lblMonthDays" class="lbl1">@Model.Details.TotalMonthDays</span></td>
                        </tr>
                        <tr>
                            <td class="lbl1">Payable Days As Per PO</td><td>:</td>
                            <td><span id="lblPayableDays" class="lbl1">@Model.Details.PayableDays</span></td>
                            <td>&nbsp;</td>
                            <td class="lbl1">Total Working Days</td><td>:</td>
                            <td><span id="lblTotalWorkingDays" class="lbl1">@Model.Details.TotalWorkingDays</span></td>
                        </tr>
                    </table>
                </td>
            </tr>

            <!-- Grid — mirrors gvPODetails GridView columns exactly -->
            <tr>
                <td colspan="2">
                    @if (Model.GridRows != null && Model.GridRows.Rows.Count > 0)
                    {
                        <table class="Grid_Item" width="100%" border="1" cellspacing="0" cellpadding="2">
                            <thead style="background-color:Gray; color:White; font-weight:bold;">
                                <tr>
                                    <td>Resource</td><td>Grade</td><td>Monthly PO Amount</td>
                                    <td>Max Fixed Amount</td><td>Max Variable(%)</td><td>Max Variable Amount</td>
                                    <td>Approved Variable(%)</td><td>Approved Variable Amount</td>
                                    <td>Payable Days</td><td>Present Working Days</td><td>Net Paid Days</td>
                                    <td>Per Day Cost</td><td>Total Amount</td><td>Deductions</td><td>Net Payable</td>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (System.Data.DataRow row in Model.GridRows.Rows)
                                {
                                    <tr>
                                        <td>@row["f_ResourceName"]</td>
                                        <td>@row["f_GradeCode"]</td>
                                        <td>@row["f_GradeMonthlyPOValue"]</td>
                                        <td>@row["f_MaxFixedAmount"]</td>
                                        <td>@row["f_MaxVariablePercentage"]</td>
                                        <td>@row["f_MaxVariableAmount"]</td>
                                        <td>@row["f_ActualVariablePercentage"]</td>
                                        <td>@row["f_ActualVariableAmount"]</td>
                                        <td>@row["f_PayableDays"]</td>
                                        <td>@row["f_PresentWorkingDays"]</td>
                                        <td>@row["f_PaidDays"]</td>
                                        <td>@row["f_PerDayCost"]</td>
                                        <td>@row["f_CreditAmount"]</td>
                                        <td>@row["f_DebitResource"]</td>
                                        <td>@row["f_NetPayable"]</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p>No record found !!!</p>
                    }
                </td>
            </tr>

            <!-- Remarks + Totals + Action buttons -->
            <tr>
                <td>
                    <table cellpadding="1" cellspacing="0" border="0" class="Text" style="padding-left:10px; padding-top:30px;">
                        <tr>
                            <td class="lbl1" align="left" valign="top" style="width:80px;">Remarks</td>
                            <td style="width:2px;" align="center" class="lbl1" valign="top">:</td>
                            <td>
                                <textarea id="txtDebitReason" name="DebitReason" class="textfield"
                                          rows="3" cols="30"
                                          @(Model.IsGenerated ? "disabled" : "")>@Model.DebitReason</textarea>
                            </td>
                        </tr>
                    </table>
                </td>
                <td align="right">
                    <table cellpadding="1" cellspacing="0" border="0" class="Text" style="padding-left:10px; padding-top:10px;">
                        <tr>
                            <td style="width:150px;" class="lbl1" align="right">Total Resource Credit</td>
                            <td style="width:2px;" align="center" class="lbl1">:</td>
                            <td><span id="lblNet" class="lbl1">@Model.TotalResourceCredit</span></td>
                        </tr>
                        <tr>
                            <td style="width:150px;" class="lbl1" align="right">Total Resource Debit</td>
                            <td style="width:2px;" align="center" class="lbl1">:</td>
                            <td><span id="lblDebit" class="lbl1">@Model.TotalResourceDebit</span></td>
                        </tr>
                        <tr>
                            <td style="width:150px;" class="lbl1" align="right">Total Company Debit</td>
                            <td style="width:2px;" align="center" class="lbl1">:</td>
                            <td><span id="lblDebitCompany" class="lbl1">@Model.TotalCompanyDebit</span></td>
                        </tr>
                        <tr>
                            <td style="width:150px;" class="lbl1" align="right">Net Payable</td>
                            <td style="width:2px;" align="center" class="lbl1">:</td>
                            <td><span id="lblGrand" class="lbl1">@Model.GrandPayable</span></td>
                        </tr>
                    </table>
                </td>
            </tr>

            <!-- Action buttons — Generate / Export Invoice / Export Covering -->
            <tr>
                <td colspan="2" style="padding-top:10px;">
                    @{
                        var hiddens = $@"
                            <input type='hidden' name='SelectedMonth'      value='{Model.Search.SelectedMonth}' />
                            <input type='hidden' name='SelectedVendorCode' value='{Model.Search.SelectedVendorCode}' />
                            <input type='hidden' name='SelectedVendorText' value='{Model.Search.SelectedVendorText}' />
                            <input type='hidden' name='SelectedPOValue'    value='{Model.Search.SelectedPOValue}' />
                            <input type='hidden' name='SelectedPOText'     value='{Model.Search.SelectedPOText}' />";
                    }

                    @if (!Model.IsGenerated)
                    {
                        <form method="post" asp-action="Generate" id="frmGenerate">
                            @Html.AntiForgeryToken()
                            @Html.Raw(hiddens)
                            <input type="hidden" name="DebitReason" id="hDebitReason" value="" />
                            <button type="submit" class="button" id="btnGenerate"
                                    onclick="document.getElementById('hDebitReason').value=document.getElementById('txtDebitReason').value">
                                Generate
                            </button>
                        </form>
                    }

                    @if (Model.IsGenerated)
                    {
                        <form method="post" asp-action="ExportInvoice" style="display:inline;">
                            @Html.AntiForgeryToken()
                            @Html.Raw(hiddens)
                            <button type="submit" class="button" id="btnExport">Export To Invoice</button>
                        </form>

                        @if (Model.ShowCoveringBtn)
                        {
                            <form method="post" asp-action="ExportCovering" style="display:inline;">
                                @Html.AntiForgeryToken()
                                @Html.Raw(hiddens)
                                <button type="submit" class="button" id="btnExportCovering">Export To Covering Letter</button>
                            </form>
                        }
                    }
                </td>
            </tr>
        </table>
    </div>
    </fieldset>
    </div>
}

@section Scripts {
<script>
    // ── Cascade: Month → Vendors ──────────────────────────────────────────
    function onMonthChange(sel) {
        const month = sel.value;
        document.getElementById('trRate').style.display   = month ? '' : 'none';
        document.getElementById('trSearch').style.display = 'none';
        const vend = document.getElementById('ddlVendor');
        vend.innerHTML = '<option value=""> -Select- </option>';
        if (!month) return;
        fetch(`/Reports/BindVendors?month=${encodeURIComponent(month)}`)
            .then(r => r.json())
            .then(data => {
                data.forEach(v => {
                    const o = document.createElement('option');
                    o.value = v.value; o.text = v.text;
                    vend.appendChild(o);
                });
            });
    }

    // ── Cascade: Vendor → PO Numbers ─────────────────────────────────────
    function onVendorChange(sel) {
        const vendorCode = sel.value;
        const month      = document.getElementById('ddlMonth').value;
        document.getElementById('trSearch').style.display = vendorCode ? '' : 'none';
        const po = document.getElementById('ddlPONo');
        po.innerHTML = '<option value=""> -Select- </option>';
        if (!vendorCode) return;
        fetch(`/Reports/BindPONumbers?month=${encodeURIComponent(month)}&vendorCode=${encodeURIComponent(vendorCode)}`)
            .then(r => r.json())
            .then(data => {
                data.forEach(p => {
                    const o = document.createElement('option');
                    o.value = p.value; o.text = p.text;
                    po.appendChild(o);
                });
            });
    }

    // ── Sync hidden fields before Search POST ────────────────────────────
    function syncHiddens() {
        const month  = document.getElementById('ddlMonth').value;
        const vSel   = document.getElementById('ddlVendor');
        const poSel  = document.getElementById('ddlPONo');
        document.getElementById('hSelectedMonth').value  = month;
        document.getElementById('hVendorCode').value     = vSel.value;
        document.getElementById('hVendorText').value     = vSel.options[vSel.selectedIndex]?.text ?? '';
        document.getElementById('hPOValue').value        = poSel.value;
        document.getElementById('hPOText').value         = poSel.options[poSel.selectedIndex]?.text ?? '';
    }
</script>
}
