<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>SYS_VENDOR_MGMT</RootNamespace>
    <AssemblyName>SYS_VENDOR_MGMT</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- PDF generation: replaces iTextSharp 5.5.13.5 (deprecated HTMLWorker) -->
    <PackageReference Include="itext7"                       Version="9.1.0" />
    <PackageReference Include="itext7.bouncy-castle-adapter" Version="9.1.0" />
    <PackageReference Include="itext7.html2pdf"              Version="6.1.0" />
    <!-- Data access -->
    <PackageReference Include="Microsoft.Data.SqlClient"     Version="5.2.2" />
    <!-- Cryptography (already up-to-date) -->
    <PackageReference Include="BouncyCastle.Cryptography"    Version="2.6.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BusinessAnalysisLayer\BusinessAnalysisLayer.csproj" />
    <ProjectReference Include="..\BusinessObject\BusinessObject.csproj" />
  </ItemGroup>

</Project>

